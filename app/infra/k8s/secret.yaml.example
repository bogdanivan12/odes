# Copy this file to secret.yaml, fill in all values, then apply:
#   kubectl apply -f secret.yaml
#
# secret.yaml is gitignored - never commit it.

apiVersion: v1
kind: Secret
metadata:
  name: odes-secret
  namespace: odes
type: Opaque
stringData:
  # MongoDB Atlas connection details
  MONGODB_USER: "<mongodb-username>"
  MONGODB_PASSWORD: "<mongodb-password>"
  MONGODB_URI: "mongodb+srv://<mongodb-username>:<mongodb-password>@<cluster>.mongodb.net/?appName=<app-name>"
  DB_NAME: "odes"

  # RabbitMQ - use a dedicated user with full permissions on vhost /
  # Create with:
  #   kubectl exec -n odes rabbitmq-0 -- rabbitmqctl add_user celery <password>
  #   kubectl exec -n odes rabbitmq-0 -- rabbitmqctl set_permissions -p / celery ".*" ".*" ".*"
  CELERY_BROKER_URL: "amqp://celery:<password>@rabbitmq:5672/"

  # Internal service URL for the API (used by the worker)
  API_URL: "http://api:8080"

  # JWT settings - generate a strong random key with: openssl rand -base64 32
  DEFAULT_ALGORITHM: "HS256"
  EXPIRES_DELTA: "30"          # access token lifetime in minutes
  REFRESH_EXPIRES_DELTA: "10080"  # refresh token lifetime in minutes (default: 7 days)
  SECRET_KEY: "<random-secret-key>"

  # Password-reset emails via Resend (https://resend.com)
  # Create an API key in Resend and verify your sending domain.
  RESEND_API_KEY: "re_<your-resend-api-key>"
  MAIL_FROM: "ODES <no-reply@your-domain>"  # must be on a Resend-verified domain
  APP_BASE_URL: "https://your-domain"       # used to build reset links in emails
  RESET_EXPIRES_DELTA: "30"                 # reset-link lifetime in minutes
