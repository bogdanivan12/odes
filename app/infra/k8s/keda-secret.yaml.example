# Copy this file to keda-secret.yaml, fill in the credentials, then apply:
#   kubectl apply -f keda-secret.yaml
#
# keda-secret.yaml is gitignored - never commit it.
#
# The RabbitMQ user must have the "monitoring" tag and read permissions on the
# management HTTP API so KEDA can query queue depths. Create it with:
#
#   kubectl exec -n odes rabbitmq-0 -- rabbitmqctl add_user keda <password>
#   kubectl exec -n odes rabbitmq-0 -- rabbitmqctl set_user_tags keda monitoring
#   kubectl exec -n odes rabbitmq-0 -- rabbitmqctl set_permissions -p / keda "" "" ".*"

apiVersion: v1
kind: Secret
metadata:
  name: rabbitmq-keda-secret
  namespace: odes
type: Opaque
stringData:
  host: "http://keda:<password>@rabbitmq.odes.svc.cluster.local:15672/"
